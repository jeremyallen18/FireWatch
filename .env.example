# FireWatch — Variables de entorno
# Copia este archivo como .env y rellena tus valores reales
# NUNCA subas el archivo .env a control de versiones

# ── Base de datos MySQL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=firewatch_2

# ── Email (SMTP) ──────────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=tu_correo@gmail.com
EMAIL_RECIPIENT=destinatario@ejemplo.com
EMAIL_PASSWORD=tu_app_password_aqui

# ── ESP32 ─────────────────────────────────────────────────────────
ESP32_IP=192.168.0.18
ESP32_PORT=80
ESP32_MODE=http
# Modos: http | mqtt | serial

# ── Detección YOLO ────────────────────────────────────────────────
MODEL_PATH=models/best.pt
DEFAULT_THRESHOLD=0.5
ALERT_COOLDOWN=30
CAMERA_SOURCE=0

# ── Aplicación ────────────────────────────────────────────────────
SECRET_KEY=genera_un_valor_secreto_largo_y_aleatorio
FLASK_DEBUG=false

# ── CORS (orígenes permitidos, separados por coma) ────────────────
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
